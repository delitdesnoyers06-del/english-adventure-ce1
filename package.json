    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.17.0",
    "workbox-window": "^7.0.0"
  },
  "keywords": [
    "pwa",
    "educational",
    "kids",
    "english",
    "ce1",
    "game",
    "svelte"
